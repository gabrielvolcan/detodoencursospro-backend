# ========================================
# BASE DE DATOS
# ========================================
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/nombre-db?retryWrites=true&w=majority

# ========================================
# AUTENTICACIÓN
# ========================================
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# ========================================
# ADMIN INICIAL (usado por scripts/poblarDB.js y como admin protegido)
# ========================================
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# ========================================
# SERVIDOR
# ========================================
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ========================================
# EMAIL - RESEND
# ========================================
RESEND_API_KEY=

# ========================================
# EMAIL - SMTP (envío masivo)
# ========================================
EMAIL_HOST=smtp.ejemplo.com
EMAIL_PORT=587
EMAIL_USER=tu-correo@ejemplo.com
EMAIL_PASS=tu-password-de-aplicacion

# ========================================
# NOTIFICACIONES - TELEGRAM
# ========================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
